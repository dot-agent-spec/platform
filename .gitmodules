[submodule "org-spec"]
	path = org-spec
	url = https://github.com/dot-agent-spec/.github.git
[submodule "dsl/tree-sitter"]
	path = packages/tree-sitter
	url = https://github.com/dot-agent-spec/tree-sitter.git
[submodule "dsl/zed-agent/grammars/agent"]
	path = apps/zed-agent/grammars/agent
	url = https://github.com/dot-agent-spec/tree-sitter.git
[submodule "dsl/language-server"]
