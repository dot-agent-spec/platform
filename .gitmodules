[submodule "dsl/kernel-dsl"]
	path = packages/kernel-dsl
	url = git@github.com:dot-agent-spec/kernel-dsl.git
[submodule "dot-agent-cli"]
	path = apps/dot-agent-cli
	url = https://github.com/dot-agent-spec/dot-agent-cli.git
