{
  "name": "dot-agent",
  "version": "1.0.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "dot-agent": "dist/cli.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@dot-agent/tree-sitter": "^0.3.2",
    "@dot-agent/kernel-dsl": "file:../dsl/kernel-dsl",
    "jszip": "^3.10.1",
    "web-tree-sitter": "^0.25.0"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "vitest": "^1.6.0",
    "@types/node": "^20.0.0",
    "tsup": "^8.0.0"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "dev": "tsup --watch"
