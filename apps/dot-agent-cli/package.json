{
  "name": "@dot-agent/cli",
  "version": "0.10.0",
  "license": "Apache-2.0",
  "description": "CLI toolkit for building, packaging, and executing deterministic FSM-based agents",
  "author": {
    "name": "Danilo Borges",
    "email": "contato@daniloborg.es",
    "url": "https://daniloborg.es"
  },
  "contributors": [
    {
      "name": "Danilo Borges",
      "email": "contato@daniloborg.es",
      "url": "https://daniloborg.es"
    }
  ],
  "homepage": "https://dot-agent.ai",
  "repository": {
    "type": "git",
    "url": "https://github.com/dot-agent-spec/platform",
    "directory": "apps/dot-agent-cli"
  },
  "bugs": {
    "url": "https://github.com/dot-agent-spec/platform/issues",
    "email": "contato@daniloborg.es"
  },
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/daniloborges"
  },
  "keywords": [
    "agent",
    "agents",
    "llm",
    "cli",
    "fsm",
    "deterministic",
    "specification",
    "workflow",
    "dot-agent"
  ],
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "dot-agent": "dist/cli.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "dependencies": {
    "@clack/prompts": "^0.9.0",
    "@dot-agent/compiler": "0.10.0",
    "@dot-agent/sdk": "0.10.0",
    "@modelcontextprotocol/sdk": "^1.29.0"
  },
  "scripts": {
    "prepare": "git config core.hooksPath .githooks",
    "prepublishOnly": "npm run build && npm run test",
    "build": "tsup",
    "test": "vitest run",
    "dev": "tsup --watch"
  },
  "publishConfig": {
    "access": "public"
  }
}
