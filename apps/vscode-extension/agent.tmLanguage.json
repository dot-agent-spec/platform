{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": ".agent DSL",
  "scopeName": "source.description",
  "patterns": [
    { "include": "#comments" },
    { "include": "#keywords" },
    { "include": "#keywordOperators" },
    { "include": "#urls" },
    { "include": "#strings" },
    { "include": "#operators" },
    { "include": "#identifiers" }
  ],
  "repository": {
    "comments": {
      "name": "comment.line.double-slash.agent",
      "match": "//.*$"
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.agent",
          "match": "^\\s*(agent|description|behavior|requires|input|capabilities|output|type|concept|schema|domain|license|terms|privacy)\\b"
        }
      ]
    },
    "keywordOperators": {
      "patterns": [
        {
          "name": "keyword.operator.agent",
          "match": "\\bEnum\\b"
        }
      ]
    },
    "urls": {
      "name": "string.special.url.agent",
      "match": "https?://[^\\s)]+"
    },
    "strings": {
      "name": "string.quoted.double.agent",
      "begin": "\"",
      "end": "\"",
      "patterns": [
        {
          "name": "constant.character.escape.agent",
          "match": "\\\\."
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.agent",
          "match": "[?:\\[\\]]"
        }
      ]
    },
    "identifiers": {
      "name": "entity.name.type.agent",
      "match": "\\b[a-zA-Z_][a-zA-Z0-9_\\-.]*\\b"
    }
  }
}
