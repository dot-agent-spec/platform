{
  "wordPattern": "(-?\\d*\\.\\d\\w*)|([a-zA-Z_][a-zA-Z0-9_.\\-]*)",
  "comments": {
    "lineComment": "//"
  },
  "brackets": [
    ["{", "}"],
    ["[", "]"],
    ["(", ")"]
  ],
  "autoClosingPairs": [
    {"open": "{", "close": "}"},
    {"open": "[", "close": "]"},
    {"open": "(", "close": ")"},
    {"open": "\"", "close": "\""}
  ],
  "surroundingPairs": [
    {"open": "{", "close": "}"},
    {"open": "[", "close": "]"},
    {"open": "(", "close": ")"},
    {"open": "\"", "close": "\""}
  ],
  "folding": {
    "offSide": true
  },
  "indentationRules": {
    "increaseIndentPattern": "^\\s*(state|on event|on intent|on offtopic|on fallback|on complete|on failed|if|else|after|parallel)\\b.*$",
    "decreaseIndentPattern": "^\\s*$"
  }
}
