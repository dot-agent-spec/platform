{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Behavior DSL",
  "scopeName": "source.behavior",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#stateDecl" },
    { "include": "#mergeDecl" },
    { "include": "#keywords" },
    { "include": "#keywordOperators" },
    { "include": "#memoryDomains" },
    { "include": "#comparisonOperators" },
    { "include": "#assignmentOperators" },
    { "include": "#logicalOperators" },
    { "include": "#booleans" },
    { "include": "#nullLiteral" },
    { "include": "#numbers" },
    { "include": "#identifiers" }
  ],
  "repository": {
    "comments": {
      "name": "comment.line.double-slash.behavior",
      "match": "//.*$"
    },
    "strings": {
      "name": "string.quoted.double.behavior",
      "begin": "\"",
      "end": "\"",
      "patterns": [
        {
          "name": "constant.character.escape.behavior",
          "match": "\\\\."
        }
      ]
    },
    "stateDecl": {
      "match": "^\\s*(state)\\s+([a-zA-Z_][a-zA-Z0-9_.\\-]*)",
      "captures": {
        "1": { "name": "keyword.control.behavior" },
        "2": { "name": "entity.name.type.behavior" }
      }
    },
    "mergeDecl": {
      "match": "^\\s*(merge)\\s+",
      "captures": {
        "1": { "name": "keyword.control.behavior" }
      }
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.behavior",
          "match": "\\b(merge|state|on|if|else|end|transition|after|parallel|run|guide|teach|goal|interact|set|apply|remove)\\b"
        }
      ]
    },
    "keywordOperators": {
      "patterns": [
        {
          "name": "keyword.operator.behavior",
          "match": "\\b(script|subagent|tool|event|intent|offtopic|prompts|css|to|failure|success)\\b"
        }
      ]
    },
    "memoryDomains": {
      "patterns": [
        {
          "name": "variable.language.behavior",
          "match": "\\b(context|session|worksession|user)\\b"
        }
      ]
    },
    "comparisonOperators": {
      "name": "keyword.operator.comparison.behavior",
      "match": "==|!=|>=|<=|>|<"
    },
    "assignmentOperators": {
      "name": "keyword.operator.assignment.behavior",
      "match": "\\+=|-=|(?<![=!<>])=(?!=)"
    },
    "logicalOperators": {
      "name": "keyword.operator.logical.behavior",
      "match": "\\b(and|or)\\b"
    },
    "booleans": {
      "name": "constant.language.boolean.behavior",
      "match": "\\b(true|false)\\b"
    },
    "nullLiteral": {
      "name": "constant.language.null.behavior",
      "match": "\\bnull\\b"
    },
    "numbers": {
      "name": "constant.numeric.behavior",
      "match": "-?[0-9]+(\\.[0-9]+)?"
    },
    "identifiers": {
      "name": "variable.other.behavior",
      "match": "\\b[a-zA-Z_][a-zA-Z0-9_\\-.]*\\b"
    }
  }
}
