{
  "name": "agent-dsl-syntax",
  "displayName": "Agent & Flow DSL",
  "description": "Syntax highlighting, hover docs, and snippets for .agent and .flow DSL files",
  "version": "1.4.0",
  "publisher": "entelekheia",
  "repository": {
    "type": "git",
    "url": "https://github.com/entelekheia/dot-agent-spec"
  },
  "main": "./extension.js",
  "activationEvents": [
    "onLanguage:agent",
    "onLanguage:flow"
  ],
  "engines": {
    "vscode": "^1.74.0"
  },
  "scripts": {
    "package": "vsce package",
    "install-ext": "code --install-extension agent-dsl-syntax-*.vsix"
  },
  "dependencies": {
    "agent-dsl-language-server": "github:daniloborges/language-server",
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@vscode/vsce": "^3.0.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "contributes": {
    "commands": [
      {
        "command": "flow.openGraph",
        "title": "Flow: Open Graph",
        "category": "Flow",
        "icon": "$(type-hierarchy)"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "flow.openGraph",
          "when": "resourceExtname == .flow",
          "group": "navigation"
        }
      ]
    },
    "languages": [
      {
        "id": "agent",
        "aliases": [
          "Agent",
          "agent"
        ],
        "extensions": [
          ".agent"
        ],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "./agent-icon.svg",
          "dark": "./agent-icon.svg"
        }
      },
      {
        "id": "flow",
        "aliases": [
          "Flow",
          "flow"
        ],
        "extensions": [
          ".flow"
        ],
        "configuration": "./flow-language-configuration.json",
        "icon": {
          "light": "./flow-icon-light.svg",
          "dark": "./flow-icon.svg"
        }
      }
    ],
    "grammars": [
      {
        "language": "agent",
        "scopeName": "source.agent",
        "path": "./agent.tmLanguage.json"
      },
      {
        "language": "flow",
        "scopeName": "source.flow",
        "path": "./flow.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "agent",
        "path": "./snippets.json"
      },
      {
        "language": "flow",
        "path": "./flow-snippets.json"
      }
    ]
  }
}
