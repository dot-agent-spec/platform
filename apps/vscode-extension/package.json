{
  "name": "vscode-dot-agent",
  "displayName": ".agent DSL",
  "description": "Syntax highlighting, hover docs, and snippets for .agent DSL files",
  "version": "0.2.0",
  "publisher": "dot-agent",
  "repository": {
    "type": "git",
    "url": "https://github.com/dot-agent-spec/vscode-dot-agent"
  },
  "main": "./extension.js",
  "activationEvents": [
    "onLanguage:agent",
    "onLanguage:behavior"
  ],
  "engines": {
    "vscode": "^1.74.0"
  },
  "scripts": {
    "package": "vsce package",
    "install-ext": "code --install-extension vscode-dot-agent-*.vsix"
  },
  "dependencies": {
    "@dot-agent/language-server": "^0.2.0",
    "@dot-agent/tree-sitter": "^0.2.0",
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@vscode/vsce": "^3.0.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "icon": "dot-agent-icon.png",
  "contributes": {
    "commands": [
      {
        "command": "behavior.openGraph",
        "title": "Behavior: Open Graph",
        "category": "Behavior",
        "icon": "$(type-hierarchy)"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "behavior.openGraph",
          "when": "resourceExtname == .behavior",
          "group": "navigation"
        }
      ]
    },
    "languages": [
      {
        "id": "agent",
        "aliases": [
          "Agent",
          "agent"
        ],
        "extensions": [
          ".description",
          ".type"
        ],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "./agent-icon.svg",
          "dark": "./agent-icon.svg"
        }
      },
      {
        "id": "behavior",
        "aliases": [
          "Behavior",
          "behavior"
        ],
        "extensions": [
          ".behavior"
        ],
        "configuration": "./behavior-language-configuration.json",
        "icon": {
          "light": "./behavior-icon-light.svg",
          "dark": "./behavior-icon.svg"
        }
      }
    ],
    "grammars": [
      {
        "language": "agent",
        "scopeName": "source.description",
        "path": "./agent.tmLanguage.json"
      },
      {
        "language": "behavior",
        "scopeName": "source.behavior",
        "path": "./behavior.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "agent",
        "path": "./snippets.json"
      },
      {
        "language": "behavior",
        "path": "./behavior-snippets.json"
      }
    ]
  }
}
