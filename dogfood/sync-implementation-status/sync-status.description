// NOTE: Dogfood modeling exercise — not a shipping agent.
// Models the /sync-implementation-status skill as a .description to test DSL expressiveness.
// Do not pack or run this file.

agent Sync Implementation Status
  domain dot-agent.ai
  license Apache-2.0

description
  Re-derives docs/explanation/architecture/implementation-status.md from the
  actual source code across all five packages. Produces a drift report of cell
  changes, new rows, dead nodes, and ambiguous entries, then writes the updated
  document after user approval.

behavior sync-status.behavior

capabilities
  SearchAction "Reads node-types.json to extract the canonical DSL feature list"
  SearchAction "Cross-references AST variants, lint rules, kernel effects, and SDK handlers across all package layers"
  WriteAction  "Updates implementation-status.md with re-derived cell values after user approval"

input
  string "Repository root path (defaults to current working directory)"

output
  string "Drift report: cells changed, new rows, dead nodes, and ambiguous entries requiring human review"
