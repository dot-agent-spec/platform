{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Flow DSL",
  "scopeName": "source.flow",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#stateDecl" },
    { "include": "#mergeDecl" },
    { "include": "#keywords" },
    { "include": "#keywordOperators" },
    { "include": "#memoryDomains" },
    { "include": "#comparisonOperators" },
    { "include": "#assignmentOperators" },
    { "include": "#logicalOperators" },
    { "include": "#booleans" },
    { "include": "#nullLiteral" },
    { "include": "#numbers" },
    { "include": "#identifiers" }
  ],
  "repository": {
    "comments": {
      "name": "comment.line.double-slash.flow",
      "match": "//.*$"
    },
    "strings": {
      "name": "string.quoted.double.flow",
      "begin": "\"",
      "end": "\"",
      "patterns": [
        {
          "name": "constant.character.escape.flow",
          "match": "\\\\."
        }
      ]
    },
    "stateDecl": {
      "match": "^\\s*(state)\\s+([a-zA-Z_][a-zA-Z0-9_.\\-]*)",
      "captures": {
        "1": { "name": "keyword.control.flow" },
        "2": { "name": "entity.name.type.flow" }
      }
    },
    "mergeDecl": {
      "match": "^\\s*(merge)\\s+",
      "captures": {
        "1": { "name": "keyword.control.flow" }
      }
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.flow",
          "match": "\\b(merge|state|on|if|else|next|after|parallel|run|guide|teach|goal|interact|set|apply|remove)\\b"
        }
      ]
    },
    "keywordOperators": {
      "patterns": [
        {
          "name": "keyword.operator.flow",
          "match": "\\b(script|subagent|tool|silent|background|each|event|intent|escape|fallback|complete|failed|requiring|prompts|css|html|video|in)\\b"
        }
      ]
    },
    "memoryDomains": {
      "patterns": [
        {
          "name": "variable.language.flow",
          "match": "\\b(context|session|worksession|user)\\b"
        }
      ]
    },
    "comparisonOperators": {
      "name": "keyword.operator.comparison.flow",
      "match": "==|!=|>=|<=|>|<"
    },
    "assignmentOperators": {
      "name": "keyword.operator.assignment.flow",
      "match": "\\+=|-=|(?<![=!<>])=(?!=)"
    },
    "logicalOperators": {
      "name": "keyword.operator.logical.flow",
      "match": "\\b(and|or)\\b"
    },
    "booleans": {
      "name": "constant.language.boolean.flow",
      "match": "\\b(true|false)\\b"
    },
    "nullLiteral": {
      "name": "constant.language.null.flow",
      "match": "\\bnull\\b"
    },
    "numbers": {
      "name": "constant.numeric.flow",
      "match": "-?[0-9]+(\\.[0-9]+)?"
    },
    "identifiers": {
      "name": "variable.other.flow",
      "match": "\\b[a-zA-Z_][a-zA-Z0-9_\\-.]*\\b"
    }
  }
}
