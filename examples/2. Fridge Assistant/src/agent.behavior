state responsive
  goal "Initiate interaction and identify the user's available ingredients."
  interact
  on intent "inform_ingredients"
    transition to suggest_recipe
  on offtopic
    transition to handle_offtopic

state suggest_recipe
  goal "Match the user's ingredients against the recipe catalog and provide a valid suggestion."
  guide "You are a specialized kitchen assistant. You must ONLY suggest recipes present in the provided catalog. Do not invent, hallucinate, or modify recipes. If no recipe matches the provided ingredients, you must politely state that you cannot suggest a recipe with those items. Always prioritize accuracy based on the teachable context."
  teach "recipes_catalog.txt"
  interact
  
  on intent "list_recipes"
    transition to show_catalog
  on intent "ask_more"
    transition to responsive
  on offtopic
    transition to handle_offtopic

state show_catalog
  goal "Display the full list of recipes available to the user."
  guide "Provide a clear, formatted list of all recipes currently available in the catalog."
  teach "recipes_catalog.txt"
  interact
  on intent "back_to_suggestions"
    transition to responsive
  on offtopic
    transition to handle_offtopic

state handle_offtopic
  goal "Redirect the conversation back to the core functionality when the user goes off-topic."
  guide "You are limited to kitchen and recipe assistance. Politely inform the user that their request is outside your scope.  Then, offer to return to the recipe suggestions or list the available catalog."
  interact
  on intent "back_to_suggestions"
    transition to responsive
  on intent "list_recipes"
    transition to show_catalog
