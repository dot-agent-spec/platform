{
  "name": "dot-agent-workspace",
  "version": "1.0.0",
  "private": true,
  "description": "dot-agent DSL Monorepo Workspace",
  "workspaces": [
    "packages/*",
    "apps/dot-agent-cli",
    "apps/vscode-extension",
    "dsl/*"
  ],
  "scripts": {
    "build": "npm run build -w packages/tree-sitter && npm run build -w packages/parser-dsl && npm run build -w packages/kernel-dsl && npm run build -w packages/compiler && npm run build -w packages/sdk && npm run build -w packages/language-server && npm run build -w apps/dot-agent-cli",
    "test": "npm run test --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "clean": "npm run clean --workspaces --if-present",
    "generate:dashboard": "node scripts/generate-dashboard.js"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "marked": "^18.0.5",
    "tsdown": "^0.22.5",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  },
  "allowScripts": {
    "tree-sitter-cli@0.25.10": true,
    "esbuild@0.21.5": true,
    "esbuild@0.27.7": true,
    "keytar@7.9.0": true,
    "@vscode/vsce-sign@2.0.9": true,
    "fsevents@2.3.3": true
  }
}
