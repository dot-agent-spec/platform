{
  "name": "@dot-agent/compiler",
  "version": "0.1.0",
  "license": "Apache-2.0",
  "description": "Compiler for the dot-agent DSL: AST parsing, linting, graph extraction and .agent packaging",
  "author": {
    "name": "Danilo Borges",
    "email": "contato@daniloborg.es",
    "url": "https://daniloborg.es"
  },
  "contributors": [
    {
      "name": "Danilo Borges",
      "email": "contato@daniloborg.es",
      "url": "https://daniloborg.es"
    }
  ],
  "homepage": "https://dot-agent.ai",
  "repository": {
    "type": "git",
    "url": "https://github.com/dot-agent-spec/platform",
    "directory": "packages/compiler"
  },
  "bugs": {
    "url": "https://github.com/dot-agent-spec/platform/issues",
    "email": "contato@daniloborg.es"
  },
  "keywords": [
    "agent",
    "agents",
    "llm",
    "dsl",
    "compiler",
    "fsm",
    "state-machine",
    "dot-agent"
  ],
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./core": {
      "types": "./dist/core.d.ts",
      "import": "./dist/core.js",
      "require": "./dist/core.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@dot-agent/parser-dsl": "*",
    "@dot-agent/tree-sitter": "*",
    "jszip": "^3.10.1",
    "web-tree-sitter": "^0.26.9"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "vitest": "^1.6.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
