{
  "name": "@dot-agent/kernel-dsl",
  "version": "0.10.1",
  "description": "WASM kernel for parsing and executing the agent behavior DSL",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "license": "Apache-2.0",
  "author": {
    "name": "Danilo Borges",
    "email": "contato@daniloborg.es",
    "url": "https://daniloborg.es"
  },
  "contributors": [
    {
      "name": "Danilo Borges",
      "email": "contato@daniloborg.es",
      "url": "https://daniloborg.es"
    }
  ],
  "homepage": "https://dot-agent.ai",
  "repository": {
    "type": "git",
    "url": "https://github.com/dot-agent-spec/platform",
    "directory": "packages/kernel-dsl"
  },
  "bugs": {
    "url": "https://github.com/dot-agent-spec/platform/issues",
    "email": "contato@daniloborg.es"
  },
  "keywords": [
    "wasm",
    "agent",
    "agents",
    "llm",
    "dsl",
    "behavior",
    "fsm",
    "state-machine",
    "parser",
    "webassembly",
    "dot-agent"
  ],
  "files": [
    "dist/",
    "pkg/"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "scripts": {
    "build": "cargo test -p dot-agent-kernel-dsl && RELEASE=true bash ../../scripts/build-wasm.sh dot_agent_kernel_dsl && tsup",
    "build:debug": "cargo test -p dot-agent-kernel-dsl && bash ../../scripts/build-wasm.sh dot_agent_kernel_dsl && tsup",
    "test:node": "node --test tests/*.test.js"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "@types/node": "^22.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
