{
  "name": "@dot-agent/behavior-parser",
  "version": "0.1.0",
  "description": "Shared behavior DSL parser and static analysis for dot-agent — parses .behavior files and provides FSM analysis utilities",
  "type": "module",
  "main": "./index.js",
  "types": "./index.d.ts",
  "exports": {
    ".": {
      "import": "./index.js",
      "types": "./index.d.ts"
    }
  },
  "files": [
    "index.js",
    "index.d.ts",
    "pkg/dot_agent_behavior_parser.js",
    "pkg/dot_agent_behavior_parser.d.ts",
    "pkg/dot_agent_behavior_parser_bg.js",
    "pkg/dot_agent_behavior_parser_bg.wasm",
    "pkg/dot_agent_behavior_parser_bg.wasm.d.ts"
  ],
  "scripts": {
    "build": "RELEASE=true ./scripts/build-wasm.sh",
    "build:debug": "./scripts/build-wasm.sh"
  },
  "keywords": ["wasm", "agent", "dsl", "parser", "fsm", "scxml"],
  "license": "Apache-2.0",
  "author": "Danilo Borges <contato@daniloborg.es>",
  "homepage": "https://dot-agent.ai",
  "repository": {
    "type": "git",
    "url": "https://github.com/dot-agent-spec/dot-agent-spec"
  }
}
