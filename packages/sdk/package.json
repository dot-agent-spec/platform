{
  "name": "@dot-agent/sdk",
  "version": "0.10.0",
  "description": "Browser-compatible SDK for loading and running dot-agent bundles",
  "license": "Apache-2.0",
  "author": {
    "name": "Danilo Borges",
    "email": "contato@daniloborg.es",
    "url": "https://daniloborg.es"
  },
  "contributors": [
    {
      "name": "Danilo Borges",
      "email": "contato@daniloborg.es",
      "url": "https://daniloborg.es"
    }
  ],
  "homepage": "https://dot-agent.ai",
  "repository": {
    "type": "git",
    "url": "https://github.com/dot-agent-spec/platform",
    "directory": "packages/sdk"
  },
  "bugs": {
    "url": "https://github.com/dot-agent-spec/platform/issues",
    "email": "contato@daniloborg.es"
  },
  "keywords": [
    "agent",
    "agents",
    "llm",
    "sdk",
    "dsl",
    "fsm",
    "wasm",
    "browser",
    "dot-agent"
  ],
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "node --test tests/node.test.js"
  },
  "dependencies": {
    "@dot-agent/compiler": "0.10.0",
    "@dot-agent/kernel-dsl": "0.10.0",
    "jszip": "^3.10.1"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
