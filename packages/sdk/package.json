{
  "name": "@dot-agent/sdk",
  "version": "0.10.3",
  "description": "Browser-compatible SDK for loading and running dot-agent bundles",
  "license": "Apache-2.0",
  "author": {
    "name": "Danilo Borges",
    "email": "contato@daniloborg.es",
    "url": "https://daniloborg.es"
  },
  "contributors": [
    {
      "name": "Danilo Borges",
      "email": "contato@daniloborg.es",
      "url": "https://daniloborg.es"
    }
  ],
  "homepage": "https://dot-agent.ai",
  "repository": {
    "type": "git",
    "url": "https://github.com/dot-agent-spec/platform",
    "directory": "packages/sdk"
  },
  "bugs": {
    "url": "https://github.com/dot-agent-spec/platform/issues",
    "email": "contato@daniloborg.es"
  },
  "keywords": [
    "agent",
    "agents",
    "llm",
    "sdk",
    "dsl",
    "fsm",
    "wasm",
    "browser",
    "dot-agent"
  ],
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.mts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "typecheck": "tsc --noEmit",
    "test": "node --test tests/*.test.js"
  },
  "dependencies": {
    "@dot-agent/compiler": "0.10.2",
    "@dot-agent/kernel-dsl": "0.10.3",
    "jszip": "^3.10.1"
  },
  "devDependencies": {
    "esbuild": "^0.21.5"
  },
  "publishConfig": {
    "access": "public"
  }
}
